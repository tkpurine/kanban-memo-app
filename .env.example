# Set a password to enable authentication (leave empty to disable)
APP_PASSWORD=

# Server port (default: 3000)
PORT=3000

# --- Local mode (default) ---
# Leave TURSO_DATABASE_URL empty to use local SQLite file

# --- Cloud mode (Turso + Render) ---
# Set these to connect to Turso cloud database
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Storage folder (only needed for local file-based cloud mode, not Turso)
STORAGE_FOLDER=
